{
  "name": "layout-adaptor-monorepo",
  "private": true,
  "version": "0.0.3",
  "description": "Responsive layout adaptor monorepo",
  "author": {
    "name": "SK-ERIC",
    "email": "graceful.sk0@gmail.com",
    "url": "https://github.com/SK-ERIC"
  },
  "license": "MIT",
  "homepage": "https://github.com/tinyforged/layout-adaptor",
  "repository": {
    "url": "https://github.com/tinyforged/layout-adaptor.git"
  },
  "bugs": {
    "url": "https://github.com/tinyforged/layout-adaptor/issues"
  },
  "scripts": {
    "dev": "pnpm -C playground dev",
    "build": "pnpm --filter @tinyforged/layout-adaptor --filter @tinyforged/layout-adaptor-vue run build",
    "build:playground": "pnpm build && pnpm -C playground build",
    "preview": "pnpm -C playground preview",
    "stub": "pnpm -r run stub",
    "lint": "eslint . --fix",
    "format": "bt prettier-write",
    "commit": "bt git-commit",
    "cleanup": "bt cleanup",
    "ncu": "bt ncu",
    "publish-pkg": "pnpm -r publish --access public",
    "typecheck": "pnpm -r run typecheck",
    "prepare": "simple-git-hooks",
    "release": "bt release && pnpm build && pnpm publish-pkg"
  },
  "devDependencies": {
    "@types/node": "^20.10.4",
    "bitsy-cli": "^0.0.4",
    "eslint": "^8.55.0",
    "eslint-config-bitsy": "^0.0.9",
    "simple-git-hooks": "^2.9.0",
    "typescript": "^5.3.3",
    "unbuild": "^2.0.0"
  },
  "simple-git-hooks": {
    "commit-msg": "pnpm bt git-commit-verify",
    "pre-commit": "pnpm bt lint-staged"
  },
  "packageManager": "pnpm@10.0.0"
}
