{
  "name": "@tinyforged/layout-adaptor",
  "version": "1.1.0",
  "description": "Framework-agnostic responsive layout adaptor for scaling containers to fit design dimensions",
  "keywords": [
    "layout",
    "adaptor",
    "scale",
    "responsive",
    "adaptation",
    "zoom",
    "rem",
    "viewport",
    "fit",
    "contain",
    "cover",
    "data-visualization",
    "dashboard",
    "large-screen",
    "auto-scaling"
  ],
  "author": {
    "name": "SK-ERIC",
    "email": "graceful.sk0@gmail.com",
    "url": "https://github.com/SK-ERIC"
  },
  "license": "MIT",
  "type": "module",
  "homepage": "https://github.com/tinyforged/layout-adaptor#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/tinyforged/layout-adaptor.git"
  },
  "bugs": {
    "url": "https://github.com/tinyforged/layout-adaptor/issues"
  },
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "main": "dist/index.cjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "sideEffects": false,
  "engines": {
    "node": ">=16"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "unbuild",
    "stub": "unbuild --stub",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "typescript": "^5.3.3",
    "unbuild": "^2.0.0"
  }
}
